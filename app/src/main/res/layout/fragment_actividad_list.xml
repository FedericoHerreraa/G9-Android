<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Filtros -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#F5F5F5">

        <EditText
            android:id="@+id/etDestino"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar por destino..."
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:textColor="@android:color/black"
            android:textColorHint="#888888"
            android:background="@android:drawable/editbox_background"/>

        <Spinner
            android:id="@+id/spinnerCategoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etPrecioMin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Precio mín"
                android:inputType="numberDecimal"
                android:padding="10dp"
                android:layout_marginEnd="4dp"
                android:textColor="@android:color/black"
                android:textColorHint="#888888"
                android:background="@android:drawable/editbox_background"/>

            <EditText
                android:id="@+id/etPrecioMax"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Precio máx"
                android:inputType="numberDecimal"
                android:padding="10dp"
                android:layout_marginStart="4dp"
                android:textColor="@android:color/black"
                android:textColorHint="#888888"
                android:background="@android:drawable/editbox_background"/>

        </LinearLayout>

        <EditText
            android:id="@+id/etFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha (YYYY-MM-DD)"
            android:inputType="date"
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:textColor="@android:color/black"
            android:textColorHint="#888888"
            android:background="@android:drawable/editbox_background"/>

        <Button
            android:id="@+id/btnFiltrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aplicar filtros"
            android:backgroundTint="#FF6B35"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Sección Destacadas/Recomendadas -->
            <LinearLayout
                android:id="@+id/layoutDestacadas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Destacadas para ti"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:padding="12dp"
                    android:textColor="@android:color/black"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDestacadas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todas las actividades"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:textColor="@android:color/black"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/red"
                android:visibility="gone"
                android:padding="16dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvActividades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <Button
                android:id="@+id/btnCargarMas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cargar más"
                android:layout_margin="16dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
