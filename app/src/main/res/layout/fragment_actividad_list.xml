<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Filtros -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#F5F5F5">

        <EditText
            android:id="@+id/etDestino"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar por destino..."
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:background="@android:drawable/editbox_background"/>

        <Spinner
            android:id="@+id/spinnerCategoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etPrecioMin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Precio mín"
                android:inputType="numberDecimal"
                android:padding="10dp"
                android:layout_marginEnd="4dp"
                android:background="@android:drawable/editbox_background"/>

            <EditText
                android:id="@+id/etPrecioMax"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Precio máx"
                android:inputType="numberDecimal"
                android:padding="10dp"
                android:layout_marginStart="4dp"
                android:background="@android:drawable/editbox_background"/>

        </LinearLayout>

        <EditText
            android:id="@+id/etFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha (YYYY-MM-DD)"
            android:inputType="date"
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:background="@android:drawable/editbox_background"/>

        <Button
            android:id="@+id/btnFiltrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aplicar filtros"
            android:backgroundTint="#FF6B35"/>

    </LinearLayout>

    <!-- Destacadas -->
    <LinearLayout
        android:id="@+id/layoutDestacadas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ Destacadas"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDestacadas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Todas las actividades"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="12dp"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_gravity="center"/>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:textSize="16sp"
        android:visibility="gone"
        android:layout_gravity="center"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvActividades"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btnCargarMas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cargar más"
        android:backgroundTint="#FF6B35"
        android:visibility="gone"/>

</LinearLayout>