<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header con título -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mi Perfil"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FF6B35"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Foto de perfil -->
        <ImageView
            android:id="@+id/ivPhoto"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_default_avatar"
            android:contentDescription="Foto de perfil"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnChangePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Cambiar foto"
            android:textSize="12sp"
            android:backgroundTint="#444444"
            android:layout_marginBottom="24dp"
            android:visibility="gone"/>

        <!-- Datos personales -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Datos personales"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre"
            android:textSize="12sp"
            android:textColor="#888888"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textSize="12sp"
            android:textColor="#888888"/>

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textColor="#333333"
            android:background="#F0F0F0"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teléfono de contacto"
            android:textSize="12sp"
            android:textColor="#888888"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- Preferencias de viaje (TPO Punto 2, item 2) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preferencias de viaje"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Se usan para personalizar las sugerencias en la Home"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp"/>

        <CheckBox
            android:id="@+id/cbAventura"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aventura"/>

        <CheckBox
            android:id="@+id/cbCultura"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cultura"/>

        <CheckBox
            android:id="@+id/cbGastronomia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gastronomía"/>

        <CheckBox
            android:id="@+id/cbNaturaleza"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Naturaleza"/>

        <CheckBox
            android:id="@+id/cbRelax"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Relax"
            android:layout_marginBottom="24dp"/>

        <!-- Resumen de actividades (TPO Punto 2, item 3) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mis actividades"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#F0F0F0"
                android:padding="16dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tvReservadas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B35"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reservadas"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#F0F0F0"
                android:padding="16dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvRealizadas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B35"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Realizadas"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Botones de acción -->
        <Button
            android:id="@+id/btnEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar perfil"
            android:backgroundTint="#FF6B35"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar cambios"
            android:backgroundTint="#FF6B35"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:backgroundTint="#888888"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
