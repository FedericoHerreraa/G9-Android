<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.desarrollo_apps_1.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.desarrollo_apps_1.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_homeFragment_to_profileFragment"
            app:destination="@id/profileFragment" />

        <action
            android:id="@+id/action_homeFragment_to_actividadListFragment"
            app:destination="@id/actividadListFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.desarrollo_apps_1.ui.profile.ProfileFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/actividadListFragment"
        android:name="com.example.desarrollo_apps_1.ui.actividades.ActividadListFragment"
        android:label="Actividades"
        tools:layout="@layout/fragment_actividad_list">
        <action
            android:id="@+id/action_actividadList_to_detail"
            app:destination="@id/actividadDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/actividadDetailFragment"
        android:name="com.example.desarrollo_apps_1.ui.actividades.ActividadDetailFragment"
        android:label="Detalle"
        tools:layout="@layout/fragment_actividad_detail">
        <argument
            android:name="actividadId"
            app:argType="integer"
            android:defaultValue="0" />
        <action
            android:id="@+id/action_detail_to_review"
            app:destination="@id/reviewFragment" />
    </fragment>

    <fragment
        android:id="@+id/reviewFragment"
        android:name="com.example.desarrollo_apps_1.ui.actividades.ReviewFragment"
        android:label="Calificar"
        tools:layout="@layout/fragment_review">
        <argument
            android:name="actividadId"
            app:argType="integer" />
    </fragment>

    <include app:graph="@navigation/auth_nav_graph" />
    <include app:graph="@navigation/home_nav_graph" />
</navigation>